# Damini Estate — environment variables
# Set these as ENCRYPTED SECRETS in Cloudflare Pages:
#   Project → Settings → Environment variables (Production + Preview)
# Never commit real values. This file documents the names only.

# GoHighLevel (required for CRM sync)
GHL_API_KEY=pit-xxxxxxxxxxxxxxxxxxxxxxxx
GHL_LOCATION_ID=xxxxxxxxxxxxxxxxxxxxxx

# GoHighLevel opportunity creation (optional — both needed to create deals)
GHL_PIPELINE_ID=
GHL_STAGE_ID=

# Resend transactional email (optional — confirmation + welcome emails)
# RESEND_FROM must be a verified sender on a verified domain.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM=Damini Estate <hello@send.daminiestate.ae>
NOTIFY_EMAIL=info@daminiestate.ae
