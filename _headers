# Cloudflare Pages headers for daminiestate.ae
# Everything is first-party (self-hosted fonts + images, no third-party scripts)
# EXCEPT the optional GoHighLevel chat widget, which is pre-allowlisted below so
# it works the moment you paste the embed into _partials/chat-widget.html.

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=(), usb=(), accelerometer=(), gyroscope=(), magnetometer=(), browsing-topics=(), interest-cohort=(), display-capture=(), serial=(), hid=(), bluetooth=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  X-XSS-Protection: 0
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin
  Content-Security-Policy: default-src 'self'; script-src 'self' https://widgets.leadconnectorhq.com; style-src 'self' 'unsafe-inline' https://widgets.leadconnectorhq.com; font-src 'self'; img-src 'self' data: https://widgets.leadconnectorhq.com https://*.leadconnectorhq.com; media-src 'self'; connect-src 'self' https://services.leadconnectorhq.com https://*.leadconnectorhq.com; frame-src https://widgets.leadconnectorhq.com https://*.leadconnectorhq.com; frame-ancestors 'none'; form-action 'self'; object-src 'none'; base-uri 'self'; upgrade-insecure-requests;
  Cache-Control: public, max-age=0, must-revalidate

# HTML pages: revalidate quickly, serve stale while doing so.
/
  Cache-Control: public, max-age=600, stale-while-revalidate=86400

# Fonts and images are stable — cache hard.
/assets/fonts/*
  Cache-Control: public, max-age=31536000, immutable
/assets/img/*
  Cache-Control: public, max-age=31536000, immutable
/assets/img/developers/*
  Cache-Control: public, max-age=31536000, immutable
/images/*
  Cache-Control: public, max-age=31536000, immutable
/*.woff2
  Cache-Control: public, max-age=31536000, immutable
/favicon.svg
  Cache-Control: public, max-age=86400
/apple-touch-icon.png
  Cache-Control: public, max-age=604800

# CSS/JS are not content-hashed on deploy → short TTL + revalidate after deploy.
/styles.css
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400
/main.js
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400
/loader-gate.js
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400
/loader-gate.js
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

/sitemap.xml
  Content-Type: application/xml; charset=utf-8
  Cache-Control: public, max-age=3600
/robots.txt
  Cache-Control: public, max-age=3600
/*.webmanifest
  Cache-Control: public, max-age=86400
